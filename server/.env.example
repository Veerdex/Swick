# Port the server listens on. Railway injects PORT automatically in production.
PORT=3001

# Origin allowed to connect via Socket.io (the Vite dev server during local dev).
CLIENT_ORIGIN=http://localhost:5173

# Supabase — used to verify player auth tokens. URL + anon key are public.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret for the persistent wallet (added in a later step). Keep private.
# SUPABASE_SERVICE_ROLE_KEY=
